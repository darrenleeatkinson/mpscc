# ---- MPSCC environment (copy to .env and fill) ----
# Postgres (transactional + PostGIS)
POSTGRES_DB=mpscc
POSTGRES_USER=mpscc
POSTGRES_PASSWORD=mpscc_dev_change_me

# TimescaleDB (location history)
TS_DB=mpscc_history
TS_USER=mpscc
TS_PASSWORD=mpscc_dev_change_me

# JWT signing secret (generate: openssl rand -base64 64)
JWT_SECRET=change_me_dev_secret_at_least_64_bytes_long_padding_padding_padding

# CORS / URLs
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://srv970497.hstgr.cloud
VITE_API_BASE_URL=http://localhost:8080

# Simulator intensity (0.0 - 2.0)
SIM_INTENSITY=1.0
